#!/usr/bin/env bash
set -euo pipefail

# ─── Config ──────────────────────────────────────────────────────────────────
REMOTE="toky"
REMOTE_DIR="~/versus"
LOCAL_DIR="/home/sam/www/samker/versus"

# ─── Couleurs ────────────────────────────────────────────────────────────────
BOLD="\033[1m"
DIM="\033[2m"
RED="\033[31m"
GREEN="\033[32m"
YELLOW="\033[33m"
CYAN="\033[36m"
WHITE="\033[97m"
RESET="\033[0m"

step() {
  echo ""
  echo -e "${BOLD}${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
  echo -e "${BOLD}${WHITE}  $1${RESET}"
  echo -e "${BOLD}${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
}

ok()   { echo -e "  ${GREEN}✔${RESET}  $1"; }
info() { echo -e "  ${DIM}${WHITE}▸ $1${RESET}"; }
fail() { echo -e "  ${RED}✘  $1${RESET}"; exit 1; }

banner() {
  echo ""
  echo -e "${BOLD}${YELLOW}╔══════════════════════════════════════════════════╗${RESET}"
  echo -e "${BOLD}${YELLOW}║          VERSUS — DEPLOY                         ║${RESET}"
  echo -e "${BOLD}${YELLOW}╚══════════════════════════════════════════════════╝${RESET}"
  echo ""
}

# ─── Main ────────────────────────────────────────────────────────────────────
banner
cd "$LOCAL_DIR"

# ── Étape 1 : Git local ───────────────────────────────────────────────────────
step "1/4 · GIT — commit & push local"

if [ -z "$(git status --porcelain)" ]; then
  info "Aucun changement local à committer"
else
  info "Ajout de tous les fichiers modifiés..."
  git add -A

  echo -e "\n  ${YELLOW}Message de commit :${RESET} \c"
  read -r COMMIT_MSG
  [ -z "$COMMIT_MSG" ] && COMMIT_MSG="deploy: mise à jour $(date '+%Y-%m-%d %H:%M')"

  git commit -m "$COMMIT_MSG"
  ok "Commit : $COMMIT_MSG"
fi

info "Push vers origin..."
git push
ok "Push effectué"

# ── Étape 2 : Build local ─────────────────────────────────────────────────────
step "2/4 · BUILD local"

info "Build frontend (Quasar)..."
cd "$LOCAL_DIR/frontend"
quasar build
ok "Frontend buildé → frontend/dist/spa/"

info "Build documentation (MkDocs)..."
cd "$LOCAL_DIR"
docker compose run --rm docs build
ok "Documentation générée → site/"

# ── Étape 3 : Rsync vers remote ───────────────────────────────────────────────
step "3/4 · RSYNC → $REMOTE"

info "Création des répertoires distants si nécessaire..."
ssh "$REMOTE" "mkdir -p $REMOTE_DIR/frontend/dist/spa $REMOTE_DIR/server/src $REMOTE_DIR/site $REMOTE_DIR/public"
ok "Répertoires distants prêts"

rsync_dir() {
  local src="$1"
  local dst="$2"
  local label="$3"
  info "Sync $label..."
  rsync -az --delete "$src" "$REMOTE:$REMOTE_DIR/$dst"
  ok "$label synchronisé"
}

rsync_dir "frontend/dist/spa/"  "frontend/dist/spa/"  "frontend/dist/spa"
rsync_dir "server/src/"         "server/src/"         "server/src"
rsync_dir "site/"               "site/"               "site (docs)"
rsync_dir "public/"             "public/"             "public"
rsync -az compose.yml "$REMOTE:$REMOTE_DIR/compose.yml"
ok "compose.yml synchronisé"

rsync_dir "server/node_modules/"  "server/node_modules/"  "server/node_modules"

# ── Étape 4 : Restart remote ──────────────────────────────────────────────────
step "4/4 · RESTART conteneurs ($REMOTE)"

info "Démarrage de tous les conteneurs..."
ssh "$REMOTE" "cd $REMOTE_DIR && docker compose up -d"
ok "Conteneurs démarrés"

# ─── Fin ─────────────────────────────────────────────────────────────────────
echo ""
echo -e "${BOLD}${GREEN}╔══════════════════════════════════════════════════╗${RESET}"
echo -e "${BOLD}${GREEN}║  ✔  Déploiement terminé avec succès !            ║${RESET}"
echo -e "${BOLD}${GREEN}╚══════════════════════════════════════════════════╝${RESET}"
echo ""
