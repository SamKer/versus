{
  "compilerOptions": {
    "target": "ES2019",
    "module": "Preserve",
    "moduleResolution": "Bundler",
    "strict": true,
    "lib": ["es2022", "dom"],
    "baseUrl": ".",
    "paths": {
      "src/*": ["src/*"],
      "app/*": ["./*"],
      "components/*": ["src/components/*"],
      "layouts/*": ["src/layouts/*"],
      "pages/*": ["src/pages/*"],
      "assets/*": ["src/assets/*"],
      "boot/*": ["src/boot/*"],
      "stores/*": ["src/stores/*"]
    },
    "skipLibCheck": true,
    "noImplicitAny": false
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts",
    "src/**/*.tsx",
    "src/**/*.vue"
  ],
  "exclude": ["node_modules"]
}
